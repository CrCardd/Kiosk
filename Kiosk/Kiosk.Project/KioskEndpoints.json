  "projectTestCaseCategories": [
    {
      "id": 1004244,
      "name": "Positivo",
      "description": "Entradas válidas e resultados esperados corretos, representando um uso típico."
    },
    {
      "id": 1004245,
      "name": "Negativo",
      "description": "Entradas negativas ou inválidas, como campos em falta, tipos incorretos, métodos não suportados, etc."
    },
    {
      "id": 1004246,
      "name": "Limite",
      "description": "Condições extremas ou de limite, como comprimento máximo de string, valores vazios, zero, null, etc."
    },
    {
      "id": 1004247,
      "name": "Segurança",
      "description": "Casos que podem expor riscos de segurança da API."
    },
    {
      "id": 1004248,
      "name": "Outros",
      "description": "Casos não classificados nas categorias existentes."
    }
  ],
  "projectTestCaseTags": [
    {
      "id": 3919668,
      "name": "Apenas campos obrigatórios",
      "description": "Enviar apenas os campos obrigatórios com valores válidos, omitindo todos os opcionais, para testar o pedido mínimo válido."
    },
    {
      "id": 3919669,
      "name": "Semântica válida",
      "description": "Usar valores sintaticamente corretos que também façam sentido na lógica de negócio ou no contexto do domínio."
    },
    {
      "id": 3919670,
      "name": "Cobertura de combinações de enum",
      "description": "Para todos os parâmetros do tipo enum, aplicar design ortogonal para construir sistematicamente combinações de casos de teste dos parâmetros e dos seus valores de enum, dedicadas a testar a cobertura de enums."
    },
    {
      "id": 3919671,
      "name": "Outro caso positivo",
      "description": "Fornecer entradas realistas e válidas que cumpram a especificação da API, produzindo o resultado correto e esperado."
    },
    {
      "id": 3919672,
      "name": "Campos obrigatórios em falta",
      "description": "Omitir um ou mais campos obrigatórios no corpo ou nos parâmetros do pedido."
    },
    {
      "id": 3919673,
      "name": "Valores inválidos",
      "description": "Fornecer valores com tipo e formato corretos, mas logicamente inválidos para o campo."
    },
    {
      "id": 3919674,
      "name": "Erros de tipo",
      "description": "Usar valores com tipos de dados incorretos, como enviar uma string em vez de um inteiro."
    },
    {
      "id": 3919675,
      "name": "Erros de formato",
      "description": "Fornecer valores num formato incorreto, p.ex., padrão de data errado, endereço de e-mail malformado."
    },
    {
      "id": 3919676,
      "name": "Erros semânticos",
      "description": "Usar valores sintática e formalmente corretos que sejam logicamente impossíveis ou violem as regras do domínio."
    },
    {
      "id": 3919677,
      "name": "Outro caso negativo",
      "description": "Fornecer entradas inválidas ou inesperadas que devem acionar o tratamento de erros ou a rejeição pela API."
    },
    {
      "id": 3919678,
      "name": "Nulo",
      "description": "Deve ser o literal JSON `null` (não vazio, não \"null\")."
    },
    {
      "id": 3919679,
      "name": "Zero",
      "description": "Deve ser o literal numérico 0."
    },
    {
      "id": 3919680,
      "name": "Valores vazios",
      "description": "Deve ser \"\"."
    },
    {
      "id": 3919681,
      "name": "Valores máximos",
      "description": "Fornecer os valores mínimo e máximo permitidos exatos para campos numéricos ou de data."
    },
    {
      "id": 3919682,
      "name": "Valores mínimos",
      "description": "Fornecer os valores mínimo e máximo permitidos exatos para campos numéricos ou de data."
    },
    {
      "id": 3919683,
      "name": "Overflow",
      "description": "Fornecer valores logo além dos limites mínimo ou máximo permitidos."
    },
    {
      "id": 3919684,
      "name": "Underflow",
      "description": "Fornecer valores logo além dos limites mínimo ou máximo permitidos."
    },
    {
      "id": 3919685,
      "name": "Strings demasiado longas",
      "description": "Fornecer strings mais longas do que o comprimento máximo permitido, ou mais curtas do que o comprimento mínimo exigido."
    },
    {
